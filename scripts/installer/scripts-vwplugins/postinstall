#!/bin/bash
# Runs as root only if the user selected "Vectorworks ConnectCAD plug-ins". Copies the
# .vsm plug-in bundles into EACH installed Vectorworks version's user Plug-ins folder, so
# Vectorworks registers the two Export commands on its next launch. No-op if Vectorworks
# isn't installed. The user still adds the commands to their workspace once
# (Tools ▸ Workspaces ▸ Edit Current Workspace ▸ drag them into a menu).
set +e
STAGE="/Library/Application Support/VectorLabel/VectorworksPlugins"
log() { /usr/bin/logger -t VectorLabel "vwplugins postinstall: $*"; }

USER_CONSOLE=$(stat -f %Su /dev/console 2>/dev/null)
[ -n "$USER_CONSOLE" ] && [ "$USER_CONSOLE" != "root" ] || exit 0
# Resolve home with the username as a LITERAL dscl argument (never `eval` — runs as ROOT).
# See the templates postinstall for the full rationale; sed keeps spaces in the path intact.
USER_HOME=$(/usr/bin/dscl . -read "/Users/$USER_CONSOLE" NFSHomeDirectory 2>/dev/null | /usr/bin/sed -n 's/^NFSHomeDirectory: //p')
[ -n "$USER_HOME" ] && [ -d "$USER_HOME" ] || { log "could not resolve home for $USER_CONSOLE"; exit 0; }
VW_BASE="$USER_HOME/Library/Application Support/Vectorworks"
[ -d "$VW_BASE" ] || exit 0   # Vectorworks not installed → nothing to do

for ver in "$VW_BASE"/*/; do
  base=$(basename "$ver")
  case "$base" in [0-9][0-9][0-9][0-9]) ;; *) continue ;; esac   # numeric year folders only
  dest="${ver}Plug-ins"
  /bin/mkdir -p "$dest" || { log "mkdir $dest failed"; continue; }
  # A Plug-ins dir we just created as root would be root-owned inside the user's tree,
  # blocking Vectorworks (runs as the user) from writing plugin caches/siblings into it.
  /usr/sbin/chown "$USER_CONSOLE" "$dest" 2>/dev/null
  for src in "$STAGE"/*.vsm; do
    [ -e "$src" ] || continue
    case "$(basename "$src")" in ._*) continue ;; esac           # skip AppleDouble sidecars
    if /bin/cp "$src" "$dest/"; then                             # overwrite: this is THE plug-in
      /usr/sbin/chown "$USER_CONSOLE" "$dest/$(basename "$src")" || log "chown $(basename "$src") failed"
    else
      log "copy of $(basename "$src") to $dest failed"
    fi
  done
done
exit 0
