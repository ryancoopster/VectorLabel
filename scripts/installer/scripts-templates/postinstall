#!/bin/bash
# Runs as root only if the user selected "Sample label templates". Copies the
# staged templates into the logged-in user's ~/Documents/VectorLabel/Templates,
# where the designers look for them. Never overwrites a template the user already
# has (matched by filename), so re-installing is safe.
set +e
STAGE="/Library/Application Support/VectorLabel/SampleTemplates"

USER_CONSOLE=$(stat -f %Su /dev/console 2>/dev/null)
[ -n "$USER_CONSOLE" ] && [ "$USER_CONSOLE" != "root" ] || exit 0
USER_HOME=$(/usr/bin/dscl . -read "/Users/$USER_CONSOLE" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
[ -n "$USER_HOME" ] || exit 0

DEST="$USER_HOME/Documents/VectorLabel/Templates"
/bin/mkdir -p "$DEST"
for f in "$STAGE"/*.vltmp; do
  [ -e "$f" ] || continue
  base=$(basename "$f")
  [ -e "$DEST/$base" ] || /bin/cp "$f" "$DEST/$base"   # don't clobber the user's own
done
/usr/sbin/chown -R "$USER_CONSOLE" "$USER_HOME/Documents/VectorLabel"
exit 0
