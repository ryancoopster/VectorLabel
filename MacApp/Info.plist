<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>VectorLabel</string>
    <key>CFBundleDisplayName</key>
    <string>VectorLabel</string>
    <key>CFBundleIdentifier</key>
    <string>com.sai.vectorlabel</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleExecutable</key>
    <string>VectorLabel</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Required for WKWebView to load local HTML files -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <!-- Privacy strings required on macOS 14+ -->
    <key>NSUSBUsageDescription</key>
    <string>VectorLabel communicates with Brady M610/M611 label printers via USB.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>VectorLabel watches ~/Documents/VectorLabel/Exports/ for CSV files and saves templates to ~/Documents/VectorLabel/Templates/.</string>
</dict>
</plist>
